; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="EduGame"
run/main_scene="uid://c80lbf6m105k2"
config/features=PackedStringArray("4.6", "C#", "GL Compatibility")

[autoload]

Managers="*res://Scenes/autoload/managers.tscn"
ChallengeUiFactoryPlugin="*res://addons/ChallengeUIFactoryPlugin/ChallengeUIFactoryPlugin.cs"

[dotnet]

project/assembly_name="EduGame"

[editor_plugins]

enabled=PackedStringArray("res://addons/ChallengeUIFactoryPlugin/plugin.cfg", "res://addons/GPUTrail-main/plugin.cfg", "res://addons/UpFaceMultiMesh/plugin.cfg")

[global_group]

occlusion_exclude="exclude object from occlusion fader"

